# Publicus Signal Engine - Production Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings > API
# SUPABASE_URL: Your Supabase project URL (e.g., https://xxxxx.supabase.co)
# SUPABASE_ANON_KEY: Your Supabase anonymous/public key (for client-side operations)
# SUPABASE_SERVICE_KEY: Your Supabase service role key (for server-side admin operations)
# ⚠️  Never commit the service key to version control!
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic API Configuration
# Get your API key from https://console.anthropic.com/
# Used for LLM classification of grant records into funding themes and procurement categories
ANTHROPIC_API_KEY=

# Environment
# Set to "production" for deployed environments
ENVIRONMENT=production

# CORS Configuration
# Comma-separated list of allowed origins (e.g., "https://yourdomain.com,https://www.yourdomain.com")
# Use "*" for prototype/testing (NOT recommended for production)
# Example: "https://publicus-signal-engine.vercel.app,https://your-railway-app.up.railway.app"
ALLOWED_ORIGINS=*
